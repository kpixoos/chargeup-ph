datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?
  full_name     String?
  auth_provider String
  created_at    DateTime @default(now())
  bookings      Booking[]
}

model Booking {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount_php  Int
  status      String   @default("pending")
  created_at  DateTime @default(now())
}
